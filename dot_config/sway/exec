exec export QT_QPA_PLATFORMTHEME=qt6ct
exec export XDG_CURRENT_DESKTOP=sway
exec systemctl --user set-environment XDG_CURRENT_DESKTOP=sway
exec systemctl --user import-environment DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP
exec systemctl --user start xdg-desktop-portal-wlr.service

exec_always gsettings set org.gnome.desktop.interface gtk-theme "Numix"
exec_always gsettings set org.gnome.desktop.wm.preferences theme "Numix"
exec_always gsettings set org.gnome.desktop.interface cursor-theme 'BreezeX-Black'
exec_always gsettings set org.gnome.desktop.interface cursor-size 32
exec_always gsettings set org.gnome.desktop.interface font-name 'BigBlueTermPlus Nerd Font 12'
