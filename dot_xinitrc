# for some reason my monitor is stuck at 60hz so this script is to force add it
# these numbers are generated by `cvt 3440 1440 144`
xrandr --newmode "3440x1440_144.00"  1086.75  3440 3744 4128 4816  1440 1443 1453 1568 -hsync +vsync
xrandr --addmode DP-1 "3440x1440_144.00"
xrandr --output DP-1 --mode "3440x1440_144.00"

# set keyboard repeat rate to 200 delay, 40 per key and start i3wm
xset r rate 200 40
exec i3
